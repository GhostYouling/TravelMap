# 服务端口。生产环境一般由 Nginx 转发到这里。
PORT=8787
HOST=127.0.0.1

# 公网地址，用于分享卡片；不填时按请求域名自动生成。
SITE_URL=

# SQLite 与媒体目录。建议生产环境放在独立数据盘并定期备份。
DATA_DIR=./data
UPLOAD_DIR=./uploads
THUMBNAIL_DIR=./thumbnails

# 单文件上限（MiB）。上传全程流式写盘，不占用等量内存。
MAX_UPLOAD_MB=2048

# 同一口令用于登录查看影像，以及授权新增/修改/删除/上传；留空则不校验。
ADMIN_TOKEN=

# 仅用于本地演示；生产建议设为 false。
SEED_DEMO=false
