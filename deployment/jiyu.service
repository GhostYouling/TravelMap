[Unit]
Description=Jiyu Travel Map
After=network.target

[Service]
Type=simple
User=jiyu
Group=jiyu
WorkingDirectory=/opt/jiyu
Environment=NODE_ENV=production
EnvironmentFile=/opt/jiyu/.env
ExecStart=/usr/bin/node /opt/jiyu/server/index.js
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/jiyu/data /opt/jiyu/uploads /opt/jiyu/thumbnails
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
