{
  "name": "jiyu-travel-map",
  "version": "1.0.0",
  "private": true,
  "description": "轻量、自托管的旅行照片与视频地图",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"node --env-file-if-exists=.env --watch server/index.js\" \"vite\"",
    "build": "tsc --noEmit && vite build",
    "start": "NODE_ENV=production node --env-file-if-exists=.env server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.4.1",
    "d3-geo": "^3.1.1",
    "express": "^5.1.0",
    "file-type": "^21.1.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "^0.34.4",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/d3-geo": "^3.1.0",
    "@types/express": "^5.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "^9.2.1",
    "supertest": "^7.1.4",
    "typescript": "5.9.3",
    "vite": "8.0.13",
    "vitest": "^4.0.17"
  }
}
